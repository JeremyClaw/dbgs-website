# Google OAuth (reused from the AIOS workspace's google-workspace MCP token)
# Same client_id/client_secret/refresh_token as credentials/google-oauth-credentials.json
# and credentials/google-token.json in the AIOS workspace. Scopes needed: calendar, gmail.send
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Lead notification routing
OPS_EMAIL=ops@deejburke.co.za
DEEJ_EMAIL=deej@deejburke.co.za

# Optional analytics id (leave blank to no-op)
NEXT_PUBLIC_ANALYTICS_ID=
